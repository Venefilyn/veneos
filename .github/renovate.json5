{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices"],

  rebaseWhen: "never",
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^Justfile$/',
      ],
      matchStrings: [
        '(?<justName>.+?)\\s:=\\s"(?<packageName>\\S+):(?<currentValue>\\S+)@(?<currentDigest>sha256:[a-f0-9]+?)"',
      ],
      datasourceTemplate: 'docker',
    },
    {
      customType: "regex",
      managerFilePatterns: [
        "/image-versions(\\.[^.]+)?\\.(yaml|yml)$/"
      ],
      datasourceTemplate: "docker",
      matchStrings: [
          "image:\\s*(?<packageName>\\S+)\\s*tag:\\s*(?<currentValue>\\S+)\\s*digest:\\s*(?<currentDigest>sha256:[a-f0-9]+)"
      ],
    }
  ],
  packageRules: [
    {
      automerge: true,
      matchUpdateTypes: ["pin", "pinDigest"]
    },
    {
      automerge: true,
      groupName: 'Build Containers',
      matchPackageNames: [
        'cgr.dev/chainguard/cosign',
        'ghcr.io/anchore/syft',
      ],
    },
    {
      automerge: true,
      matchManagers: [
        'github-actions',
      ],
      matchUpdateTypes: [
        'pin',
        'digest',
        'pinDigest',
      ],
    }
  ],
}
